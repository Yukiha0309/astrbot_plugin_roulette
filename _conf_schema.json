{
  "super_admins": {
    "type": "list",
    "description": "超级管理员 QQ 号",
    "hint": "这里填写的用户可以结束游戏或处决挂机玩家。房主不需要填写，也拥有创建房间的管理权。",
    "default": []
  },
  "whitelist_groups": {
    "type": "list",
    "description": "群聊白名单",
    "hint": "若填写，则插件仅在这些群生效。",
    "default": []
  },
  "blacklist_groups": {
    "type": "list",
    "description": "群聊黑名单",
    "hint": "这些群将禁用本插件。",
    "default": []
  },
  "max_players": {
    "type": "int",
    "description": "最大玩家数",
    "hint": "默认 6。可以调高到 7 人或以上，但超过 6 人后平衡性与回合节奏可能下降。",
    "default": 6,
    "slider": {
      "min": 2,
      "max": 12,
      "step": 1
    }
  },
  "use_player_codes": {
    "type": "bool",
    "description": "使用玩家代号",
    "hint": "开启后对局内玩家显示为 P1、P2 等，开局会公布代号对应关系。",
    "default": true
  },
  "player_name_max_length": {
    "type": "int",
    "description": "玩家名最大显示长度",
    "hint": "关闭玩家代号或展示代号映射时使用，过长会自动截断。",
    "default": 8,
    "slider": {
      "min": 4,
      "max": 20,
      "step": 1
    }
  },
  "jiuhu_event_enabled": {
    "type": "bool",
    "description": "酒狐事件开关",
    "hint": "仅异界战争模式生效。",
    "default": true
  },
  "jiuhu_event_chance": {
    "type": "int",
    "description": "酒狐事件概率",
    "hint": "每个弹仓轮开始时触发酒狐事件的概率，仅异界战争模式生效。推荐 30。",
    "default": 30,
    "slider": {
      "min": 0,
      "max": 100,
      "step": 5
    }
  }
}
